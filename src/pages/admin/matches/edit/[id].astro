---
import { createAstroSupabase } from "@/lib/supabase";
import { Icon } from "astro-icon/components";
import Alert from "@/components/shared/Alert.astro";
import Main from "@/layouts/Main.astro";
import Title from "@/components/shared/Title.astro";

const supabase = createAstroSupabase(Astro);
const {
  data: { user },
} = await supabase.auth.getUser();
if (!user) {
  return Astro.redirect("/login");
}

const { id } = Astro.params;
let errorMessage = "";
const showSuccess = Astro.url.searchParams.get("success") === "true";

// 1. Obtener datos para llenar el formulario
// A. El partido actual
const { data: match } = await supabase
  .from("matches")
  .select(
    "id, date, field_id, result, video_url, match_players(player_id, team)",
  )
  .eq("id", id)
  .single();

// Si no existe el partido, volvemos a la lista (o da error si no manejas el 404 manual)
if (!match) return Astro.redirect("/admin/matches");

// B. Listas para los selectores (Canchas y Jugadores)
const { data: fields } = await supabase
  .from("fields")
  .select("id, name")
  .order("name");
const { data: players } = await supabase
  .from("players")
  .select("id, nickname, is_guest")
  .eq("is_active", true) // <--- Agrega esto
  .order("is_guest", { ascending: true })
  .order("nickname", { ascending: true });

// C. Calcular quién jugaba dónde para marcar los checkboxes
const lightIds = match.match_players
  .filter((mp: any) => mp.team === "light")
  .map((mp: any) => String(mp.player_id));
const darkIds = match.match_players
  .filter((mp: any) => mp.team === "dark")
  .map((mp: any) => String(mp.player_id));

// --- LÓGICA DE GUARDADO (POST) ---
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();

    // 1. Datos básicos y validaciones de entrada
    const date = formData.get("date")?.toString().trim() ?? "";
    const field_id = formData.get("field_id")?.toString().trim() ?? "";
    const result = formData.get("result")?.toString().trim() ?? "";
    const video_url = formData.get("video_url")?.toString().trim() ?? "";

    if (!date || !field_id || !result) {
      throw new Error("Faltan datos obligatorios para actualizar el partido.");
    }
    if (!["light", "dark", "draw"].includes(result)) {
      throw new Error("El resultado seleccionado no es válido.");
    }
    const selectedField = fields?.find(
      (field) => String(field.id) === field_id,
    );
    if (!selectedField) {
      throw new Error("La sede seleccionada no es válida.");
    }

    // 2. Recolectar jugadores por equipo
    const playerIdByKey = new Map<string, string | number>();
    players?.forEach((player) => {
      playerIdByKey.set(String(player.id), player.id);
    });

    const newLightKeys: string[] = [];
    const newDarkKeys: string[] = [];
    players?.forEach((player) => {
      const key = String(player.id);
      const selection = formData.get(`player_${key}`);
      if (selection === "light") newLightKeys.push(key);
      if (selection === "dark") newDarkKeys.push(key);
    });

    if (newLightKeys.length === 0 || newDarkKeys.length === 0) {
      throw new Error("Debes seleccionar al menos un jugador por equipo.");
    }

    const overlap = newLightKeys.some((key) => newDarkKeys.includes(key));
    if (overlap) {
      throw new Error("Un jugador no puede estar en ambos equipos.");
    }

    const resolvePlayerId = (key: string) => {
      const value = playerIdByKey.get(key);
      if (value === undefined) {
        throw new Error("No se pudo resolver un jugador seleccionado.");
      }
      return value;
    };

    const newPlayers = [
      ...newLightKeys.map((key) => ({
        match_id: id,
        player_id: resolvePlayerId(key),
        team: "light",
      })),
      ...newDarkKeys.map((key) => ({
        match_id: id,
        player_id: resolvePlayerId(key),
        team: "dark",
      })),
    ];

    // 3. Actualizar tabla MATCHES
    const { error: matchUpdateError } = await supabase
      .from("matches")
      .update({
        date,
        field_id: selectedField.id,
        result,
        video_url: video_url || null,
      })
      .eq("id", id);

    if (matchUpdateError) {
      throw new Error(
        "No se pudo actualizar la información general del partido.",
      );
    }

    // 4. Actualizar equipos (con rollback de mejor esfuerzo)
    const originalAssignments =
      match.match_players?.map((mp: any) => ({
        match_id: id,
        player_id: mp.player_id,
        team: mp.team,
      })) ?? [];

    const { error: deleteError } = await supabase
      .from("match_players")
      .delete()
      .eq("match_id", id);

    if (deleteError) {
      throw new Error(
        "No se pudieron limpiar los equipos anteriores del partido.",
      );
    }

    const { error: insertError } = await supabase
      .from("match_players")
      .insert(newPlayers);

    if (insertError) {
      // rollback: limpiar cualquier inserción parcial e intentar restaurar estado previo
      const { error: cleanupError } = await supabase
        .from("match_players")
        .delete()
        .eq("match_id", id);

      let rollbackError = null;
      if (originalAssignments.length > 0) {
        const { error } = await supabase
          .from("match_players")
          .insert(originalAssignments);
        rollbackError = error;
      }

      if (cleanupError || rollbackError) {
        throw new Error(
          "No se pudieron guardar los equipos y tampoco se pudo restaurar el estado anterior.",
        );
      }

      throw new Error(
        "No se pudieron guardar los equipos del partido. Se restauró el estado anterior.",
      );
    }

    return Astro.redirect(`/admin/matches/edit/${id}?success=true`);
  } catch (error: any) {
    errorMessage =
      error?.message ||
      "No se pudo actualizar el partido. Por favor, intenta más tarde.";
  }
}
---

<Main title="Editar Partido | SGSC" contentWidth="admin">
  <Title title="Editar Partido" subtitle="Panel de Administración" />

  {/* Alertas */}
  {
    showSuccess && (
      <div class="mb-6 flex flex-col gap-2">
        <Alert type="success" message="¡Partido actualizado correctamente!" />
        <a
          href="/admin/matches"
          class="btn btn-ghost btn-sm w-full rounded-xl sm:w-fit"
        >
          <Icon name="material-symbols:arrow-back" size={18} />
          Volver al historial
        </a>
      </div>
    )
  }
  {errorMessage && <Alert type="error" message={errorMessage} class="mb-6" />}

  <form method="POST" class="space-y-6">
    {/* Sección: Información General */}
    <div
      class="bg-base-100 border-base-200 space-y-6 rounded-xl border p-4 shadow-md sm:p-6"
    >
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:gap-6">
        {/* Fecha */}
        <div class="form-control">
          <fieldset class="fieldset">
            <legend class="fieldset-legend">Fecha del Partido</legend>
            <input
              type="date"
              name="date"
              class="input input-bordered w-full rounded-xl"
              required
              value={match.date}
            />
          </fieldset>
        </div>

        {/* Sede */}
        <div class="form-control">
          <fieldset class="fieldset">
            <legend class="fieldset-legend">Sede</legend>
            <select
              name="field_id"
              required
              class="select select-bordered w-full rounded-xl"
            >
              {
                fields?.map((f) => (
                  <option value={f.id} selected={f.id === match.field_id}>
                    {f.name}
                  </option>
                ))
              }
            </select>
          </fieldset>
        </div>

        {/* Resultado */}
        <div class="form-control">
          <fieldset class="fieldset">
            <legend class="fieldset-legend">Resultado Final </legend>
            <select
              name="result"
              required
              class="select select-bordered w-full rounded-xl font-bold"
            >
              <option value="light" selected={match.result === "light"}>
                Claro
              </option>
              <option value="dark" selected={match.result === "dark"}>
                Oscuro
              </option>
              <option value="draw" selected={match.result === "draw"}>
                Empate
              </option>
            </select>
          </fieldset>
        </div>

        {/* Video URL */}
        <div class="form-control">
          <fieldset class="fieldset">
            <legend class="fieldset-legend">Enlace de Video</legend>
            <input
              type="url"
              name="video_url"
              class="input input-bordered w-full rounded-xl"
              placeholder="https://..."
              value={match.video_url}
            />
          </fieldset>
        </div>
      </div>
    </div>

    {/* Divider */}
    <div
      class="divider text-base-content/60 text-xs font-bold tracking-wider uppercase"
    >
      Convocatoria
    </div>

    {/* Sección: Equipos */}
    <div
      class="bg-base-100 border-base-200 max-h-96 overflow-auto rounded-xl border shadow-md"
    >
      {/* Header */}
      <div
        class="bg-base-200 sticky top-0 z-10 grid grid-cols-[1fr_2.5rem_2.5rem_2.5rem] items-center gap-1 px-3 py-2 sm:grid-cols-[1fr_3rem_3rem_3rem] sm:gap-2"
      >
        <span class="text-xs font-bold sm:text-sm">Jugador</span>
        <span class="text-base-content/60 text-center text-xs">—</span>
        <span class="flex justify-center">
          <Icon
            name="material-symbols:wb-sunny"
            class="text-base text-slate-500 sm:text-xl dark:text-slate-300"
          />
        </span>
        <span class="flex justify-center">
          <Icon
            name="material-symbols:dark-mode"
            class="text-base text-slate-500 sm:text-xl dark:text-slate-300"
          />
        </span>
      </div>

      {/* Filas de jugadores */}
      <div class="divide-base-200 divide-y">
        {
          players?.map((p) => {
            const playerId = String(p.id);
            const isLight = lightIds.includes(playerId);
            const isDark = darkIds.includes(playerId);
            const isNone = !isLight && !isDark;

            return (
              <div class="hover:bg-base-200/50 grid grid-cols-[1fr_2.5rem_2.5rem_2.5rem] items-center gap-1 px-3 py-2 transition-colors sm:grid-cols-[1fr_3rem_3rem_3rem] sm:gap-2">
                {/* Nombre */}
                <div class="flex min-w-0 items-center gap-1">
                  <span
                    class="tooltip tooltip-right truncate text-xs font-bold sm:text-sm"
                    data-tip={p.nickname}
                  >
                    {p.nickname}
                  </span>
                  {p.is_guest && (
                    <span class="badge badge-ghost badge-xs border-base-300 shrink-0 opacity-60">
                      INV
                    </span>
                  )}
                </div>

                {/* No juega */}
                <div class="flex justify-center">
                  <input
                    type="radio"
                    name={`player_${p.id}`}
                    value="none"
                    class="radio radio-xs sm:radio-sm radio-error"
                    checked={isNone}
                  />
                </div>

                {/* Claro */}
                <div class="flex justify-center rounded">
                  <input
                    type="radio"
                    name={`player_${p.id}`}
                    value="light"
                    class="radio radio-xs sm:radio-sm radio-warning"
                    checked={isLight}
                  />
                </div>

                {/* Oscuro */}
                <div class="flex justify-center rounded">
                  <input
                    type="radio"
                    name={`player_${p.id}`}
                    value="dark"
                    class="player-selector radio radio-xs sm:radio-sm radio-neutral dark:radio-primary"
                    checked={isDark}
                  />
                </div>
              </div>
            );
          })
        }
      </div>
    </div>

    {/* Botones de acción */}
    <div
      class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
    >
      <a
        href="/admin/matches"
        class="btn btn-outline btn-error order-2 w-full rounded-xl sm:order-1 sm:w-auto"
      >
        <Icon name="material-symbols:arrow-back" size={18} />
        Cancelar
      </a>
      <button type="submit" class="btn btn-primary order-1 grow rounded-xl">
        <Icon name="material-symbols:save" size={20} />
        Guardar Cambios
      </button>
    </div>
  </form>
</Main>
